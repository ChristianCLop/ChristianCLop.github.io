---
import Layout from "../layouts/Layout.astro";
import "animate.css";
import "../css/styles.css";
import Skill from "../sections/skill.astro";
import Experience from "../components/Experience.astro";
import Project from "../sections/project.astro";
import Archivement from "../sections/archivement.astro";
import Experiences from "../sections/experiences.astro";
---

<Layout title="Christian Chico">
  <main>
    <div
      id="particles-js"
      class="fixed w-screen h-screen hover:pointer-events-auto opacity-70 bg-transparent"
    >
    </div>

    <section id="home" class="overflow-hidden">
      <script src="/scripts/particles.min.js" is:inline></script>

      <script>
        document.addEventListener("DOMContentLoaded", async (event) => {
          const response = await fetch("/particlesjs-config.json");
          const particlesConfig = await response.json();
          particlesJS("particles-js", particlesConfig);
        });
      </script>

      <div class="content h-screen flex flex-col items-center justify-center">
        <div class="text flex flex-col items-start justify-center max-sm:mx-10">
          <div data-aos="fade-down-right" class="flex items-center">
            <p
              class="text-[30px] text-[#d8d8d8] font-normal animate__animated animate__bounce animate__infinite animate__slower"
            >
              Hi 👋, I'm
            </p>
          </div>

          <h1
            class="font-mono text-7xl font-black text-transparent stroke-1 max-sm:text-5xl"
          >
            Christian Chico
          </h1>

          <div class="social-links">
            <a
              data-aos="fade-up"
              data-aos-anchor-placement="top-bottom"
              class="in"
              target="_blank"
              href="https://www.linkedin.com/in/christianchicolópez"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                height="20"
                width="20"
                class=""
              >
                <path
                  stroke="#fff"
                  stroke-linejoin="round"
                  d="M1.5 3.5a2 2 0 1 0 4 0 2 2 0 1 0 -4 0"
                  stroke-width="1"></path>
                <path
                  stroke="#fff"
                  stroke-linejoin="round"
                  d="M1.5 22.5v-14h4v14h-4Z"
                  clip-rule="evenodd"
                  stroke-width="1"></path>
                <path
                  stroke="#fff"
                  stroke-linejoin="round"
                  d="M8 8.5v14h4v-6.908c0 -1.092 1 -3.092 3.895 -3.092 1.643 0 2.605 0.845 2.605 2.5v7.5h4V15c0 -1.309 -0.312 -2.937 -1.394 -4.277 -1.144 -1.417 -2.913 -2.223 -5.21 -2.223 -1.513 0 -2.835 0.615 -3.896 1.366V8.5H8Z"
                  clip-rule="evenodd"
                  stroke-width="1"></path>
              </svg>
            </a>

            <a
              data-aos="fade-up"
              data-aos-anchor-placement="top-bottom"
              class="git"
              target="_blank"
              href="https://github.com/ChristianCLop"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                height="24"
                width="24"
              >
                <path
                  stroke="#fff"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M11.996 1.771a10.486 10.486 0 0 0 -3.314 20.438c0.523 0.092 0.69 -0.216 0.69 -0.493 0 -0.25 0.005 -0.945 0 -1.824 -2.919 0.633 -3.522 -1.381 -3.522 -1.381a2.775 2.775 0 0 0 -1.163 -1.534c-0.952 -0.65 0.071 -0.638 0.071 -0.638a2.201 2.201 0 0 1 1.607 1.08 2.232 2.232 0 0 0 3.05 0.871c0.05 -0.53 0.285 -1.025 0.666 -1.397 -2.328 -0.266 -4.776 -1.165 -4.776 -5.184a4.055 4.055 0 0 1 1.08 -2.815 3.762 3.762 0 0 1 0.103 -2.774s0.882 -0.282 2.883 1.076a9.924 9.924 0 0 1 5.252 0c2.007 -1.357 2.881 -1.076 2.881 -1.076 0.387 0.878 0.424 1.87 0.104 2.774a4.05 4.05 0 0 1 1.079 2.816c0 4.03 -2.452 4.916 -4.789 5.174a2.487 2.487 0 0 1 0.718 1.933v2.904c0 0.28 0.17 0.59 0.702 0.488a10.487 10.487 0 0 0 -3.322 -20.438v0Z"
                  stroke-width="1"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="overflow-hidden">
      <div class="flex flex-col items-center justify-start mx-36 my-36">
        <h1
          class="font-mono text-7xl max-sm:text-5xl font-black text-transparent stroke-1 uppercase max-sm:whitespace-nowrap"
        >
          About Me
        </h1>
        <div
          class="flex flex-row mt-20 justify-center items-center space-x-8 max-lg:flex max-lg:flex-col max-md:flex max-md:flex-col max-sm:flex max-sm:flex-col"
        >
          <div class="max-md:w-[200px]">
            <div
              class="border rounded-full pulsate-border"
              style="border-color: #ffrgb(255, 255, 255)-border-glow-color: rgba(129, 14, 20, 0.6); --border-glow-color-stronger: rgba(224, 251, 252, 0.8);"
            >
              <img
                class="object-cover rounded-[50%] w-full max-lg:w-[200px]"
                src="https://avatars.githubusercontent.com/u/93953404?v=4"
                alt="Foto de Christian Chico"
              />
            </div>
            <div class="justify-center text-center">
              <p
                class="p-2 rounded-xl border border-[#3a8f49] text-[#3a8f49] bg-[#0d1e1b] mt-5 max-lg:mb-[50px] max-xl:whitespace-nowrap"
              >
                Open to work
              </p>
            </div>
          </div>
          <div
            class="flex flex-col justify-center items-start text-justify mx-8 max-md:w-[300px] max-md:text-justify max-sm:w-[250px] max-sm:justify-center"
          >
            <p class="text-lg font-medium font-mono">
              I'm, an software engineer, I am a passionate Full-Stack developer
              with experience in different technologies for backend, frontend
              and database development, from Ecuador, currently searching for a
              job. I've been working on many projects developing movil and web
              applications throw all my studies. Currently, I am expanding my
              knowledge in Arch Linux.
            </p>
            <br />
            <p class="text-lg font-medium font-mono">
              My goal is to course a Master's degree in Cybersecurity.
            </p>
            <br />
            <p class="text-lg font-medium font-mono">
              On my free time I love to learn about new technologies, and I am a
              big fan of cybersecurity and ethical hacking.
            </p>
          </div>
        </div>
      </div>
    </section>

    <Skill/>

    <Experiences/>

    <Archivement />

    <Project />

    <section id="contact">
      <div class=""></div>
    </section>
  </main>
</Layout>
