---
import '../css/header.css';

const navLinks = [
  { href: '#home', i18nKey: 'nav.home', defaultLabel: 'Home' },
  { href: '#about', i18nKey: 'nav.about', defaultLabel: 'About' },
  { href: '#education', i18nKey: 'nav.education', defaultLabel: 'Education' },
  { href: '#skills', i18nKey: 'nav.skills', defaultLabel: 'Stack' },
  {
    href: '#experience',
    i18nKey: 'nav.experience',
    defaultLabel: 'Experience',
  },
  { href: '#projects', i18nKey: 'nav.projects', defaultLabel: 'Projects' },
  {
    href: '#achievements',
    i18nKey: 'nav.achievements',
    defaultLabel: 'Achievements',
  },
  { href: '#contact', i18nKey: 'nav.contact', defaultLabel: 'Contact' },
];

const cvLinkEn =
  'https://drive.google.com/file/d/1XbBikzocVqpa5tyKPSLjxTXIEM8fUI6d/view?usp=sharing';
const cvLinkEs =
  'https://drive.google.com/file/d/1PnJsoBNg9QXnmodGqcg-eIS0SiP4o6hy/view?usp=sharing';
---

<header class="nav-header fixed top-0 inset-x-0 z-50">
  <!-- Top scan line -->
  <div class="nav-scanline"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-18">
      <!-- ── Logo ── -->
      <a
        href="#"
        class="logo-wrap flex items-center gap-2.5 shrink-0 group"
        aria-label="Home"
      >
        <img
          src="/logos/AllWhiteLogo.svg"
          alt="Logo"
          class="h-10 sm:h-12 w-auto"
        />
      </a>

      <!-- ── Desktop nav ── -->
      <nav
        class="hidden md:flex items-center gap-1"
        aria-label="Main navigation"
      >
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="nav-link group/link relative font-mono text-xs uppercase tracking-widest
              px-3 py-2 rounded-sm text-white/40 hover:text-white
              transition-colors duration-200"
            >
              <span class="absolute inset-0 rounded-sm bg-white/0 group-hover/link:bg-white/[0.04] transition-colors duration-200" />
              <span
                class="nav-dot absolute bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full
              bg-[#4ade80] opacity-0 scale-0
              transition-all duration-200"
              />
              <span class="relative" data-i18n={link.i18nKey}>
                {link.defaultLabel}
              </span>
            </a>
          ))
        }
      </nav>

      <!-- ── Desktop: Lang Toggle + CV button ── -->
      <div class="hidden md:flex items-center gap-3">
        <!-- Lang Toggle -->
        <div class="lang-toggle" role="group" aria-label="Language selector">
          <button
            data-lang-btn="en"
            onclick="window.applyLang('en')"
            aria-label="English"
          >
            EN
          </button>
          <span class="lang-sep" aria-hidden="true"></span>
          <button
            data-lang-btn="es"
            onclick="window.applyLang('es')"
            aria-label="Español"
          >
            ES
          </button>
        </div>

        <!-- CV button -->
        <a
          id="cv-link-desktop"
          href={cvLinkEn}
          data-href-en={cvLinkEn}
          data-href-es={cvLinkEs}
          target="_blank"
          rel="noopener noreferrer"
          class="cv-btn group relative overflow-hidden font-mono text-xs uppercase tracking-widest
            px-5 py-2 rounded-md"
        >
          <span class="cv-bg"></span>
          <span class="cv-border"></span>
          <span
            class="relative z-10 flex items-center gap-2 text-[#4ade80]/70 group-hover:text-[#4ade80] transition-colors duration-300"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-[#4ade80]/60 group-hover:bg-[#4ade80] group-hover:animate-pulse transition-colors duration-300"
            ></span>
            <span data-i18n="nav.downloadCV">Get my Resume</span>
          </span>
        </a>
      </div>

      <!-- ── Mobile menu button ── -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex flex-col items-center justify-center gap-1.5 p-2 rounded-md
          border border-white/8 bg-white/[0.02]
          hover:border-[#4ade80]/25 hover:bg-[#4ade80]/[0.04]
          transition-all duration-200"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span
          class="hamburger-line w-5 h-px bg-white/50 transition-all duration-300"
        ></span>
        <span
          class="hamburger-line w-5 h-px bg-white/50 transition-all duration-300"
        ></span>
        <span
          class="hamburger-line w-5 h-px bg-white/50 transition-all duration-300"
        ></span>
      </button>
    </div>
  </div>

  <!-- ── Mobile menu panel ── -->
  <div
    id="mobile-menu"
    class="mobile-menu md:hidden overflow-hidden"
    aria-hidden="true"
  >
    <div class="border-t border-white/8 bg-[#0d1117]/95 backdrop-blur-md">
      <!-- Terminal-style label + lang toggle mobile -->
      <div class="px-5 pt-4 pb-2 flex items-center justify-between">
        <span
          class="font-mono text-[10px] text-white/20 tracking-[0.2em] uppercase"
        >
          // navigation
        </span>

        <!-- Lang Toggle mobile -->
        <div class="lang-toggle" role="group" aria-label="Language selector">
          <button
            data-lang-btn="en"
            onclick="window.applyLang('en')"
            aria-label="English"
          >
            EN
          </button>
          <span class="lang-sep" aria-hidden="true"></span>
          <button
            data-lang-btn="es"
            onclick="window.applyLang('es')"
            aria-label="Español"
          >
            ES
          </button>
        </div>
      </div>

      <nav class="px-3 pb-4 flex flex-col gap-1">
        {
          navLinks.map((link, i) => (
            <a
              href={link.href}
              class="mobile-nav-link group flex items-center gap-3
              px-3 py-3 rounded-md font-mono text-sm text-white/50
              hover:text-white hover:bg-white/[0.04]
              transition-all duration-200"
              style={`animation-delay: ${i * 40}ms`}
            >
              <span class="font-mono text-[10px] text-[#4ade80]/30 w-4 text-right select-none">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="text-white/15">→</span>
              <span
                class="uppercase tracking-widest text-xs"
                data-i18n={link.i18nKey}
              >
                {link.defaultLabel}
              </span>
              <span class="ml-auto text-white/10 group-hover:text-[#4ade80]/40 transition-colors duration-200 text-xs">
                ▸
              </span>
            </a>
          ))
        }
      </nav>

      <!-- CV button mobile -->
      <div class="px-5 pb-5 pt-2 border-t border-white/5">
        <a
          id="cv-link-mobile"
          href={cvLinkEn}
          data-href-en={cvLinkEn}
          data-href-es={cvLinkEs}
          target="_blank"
          rel="noopener noreferrer"
          class="cv-btn group relative overflow-hidden font-mono text-xs uppercase tracking-widest
            w-full flex justify-center px-5 py-3 rounded-md"
        >
          <span class="cv-bg"></span>
          <span class="cv-border"></span>
          <span
            class="relative z-10 flex items-center gap-2 text-[#4ade80]/70 group-hover:text-[#4ade80] transition-colors duration-300"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-[#4ade80]/60 group-hover:bg-[#4ade80] group-hover:animate-pulse transition-colors duration-300"
            ></span>
            <span data-i18n="nav.downloadCV">Download CV</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</header>

<div class="h-16 sm:h-18"></div>

<script is:inline>
  // ── CV link lang switcher ──
  function updateCvLinks(lang) {
    ['cv-link-desktop', 'cv-link-mobile'].forEach(function (id) {
      var el = document.getElementById(id);
      if (!el) return;
      var href =
        el.getAttribute('data-href-' + lang) || el.getAttribute('data-href-en');
      if (href) el.setAttribute('href', href);
    });
  }

  // Patch window.applyLang to also update CV links
  document.addEventListener('DOMContentLoaded', function () {
    var _original = window.applyLang;
    window.applyLang = function (lang) {
      _original && _original(lang);
      updateCvLinks(lang);
    };
    // Apply on load based on saved lang
    updateCvLinks(localStorage.getItem('lang') || 'en');
  });

  document.addEventListener('DOMContentLoaded', () => {
    (function () {
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const lines = btn?.querySelectorAll('.hamburger-line');
      let isOpen = false;

      function toggleMenu() {
        isOpen = !isOpen;
        btn?.setAttribute('aria-expanded', String(isOpen));
        menu?.setAttribute('aria-hidden', String(!isOpen));

        if (isOpen) {
          menu?.classList.add('is-open');
          lines?.[0].classList.add('rotate-45', 'translate-y-[7px]');
          lines?.[1].classList.add('opacity-0');
          lines?.[2].classList.add('-rotate-45', '-translate-y-[7px]');
        } else {
          menu?.classList.remove('is-open');
          lines?.[0].classList.remove('rotate-45', 'translate-y-[7px]');
          lines?.[1].classList.remove('opacity-0');
          lines?.[2].classList.remove('-rotate-45', '-translate-y-[7px]');
        }
      }

      btn?.addEventListener('click', toggleMenu);

      menu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          if (isOpen) toggleMenu();
        });
      });

      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('.nav-link');

      function onScroll() {
        let current = '';
        sections.forEach((section) => {
          const top = section.getBoundingClientRect().top;
          if (top <= 80) current = section.id;
        });

        navLinks.forEach((link) => {
          const dot = link.querySelector('.nav-dot');
          const href = link.getAttribute('href')?.replace('#', '');
          const isActive = href === current || (current === '' && href === '');
          link.classList.toggle('text-white', isActive);
          link.classList.toggle('text-white/40', !isActive);
          if (dot) {
            dot.classList.toggle('opacity-100', isActive);
            dot.classList.toggle('scale-100', isActive);
            dot.classList.toggle('opacity-0', !isActive);
            dot.classList.toggle('scale-0', !isActive);
          }
        });
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  });
</script>
