---
interface Props {
  img: string;
  img2: string;
  title: string;
  date: string;
  item1: string;
  item2: string;
  item3?: string;
  item4?: string;
  item5?: string;
  skills?: {
    name: string;
    img: string;
  }[];
  compact?: boolean;
}

const {
  img,
  img2,
  title,
  date,
  item1,
  item2,
  item3,
  item4,
  item5,
  skills,
  compact = false,
} = Astro.props;
---

<li
  data-aos="fade-up"
  data-aos-duration="1200"
  class={`link-card ${compact ? "compact" : ""}`}
>
  <div class="card-content">
    
    <!-- HEADER -->
    <div class="card-header">
      <div class="logos">
        <img src={img} alt={title} />
        {!compact && img2 && <img src={img2} alt={title} />}
      </div>

      <div>
        <h2 class="title">{title}</h2>
        <p class="date">{date}</p>
      </div>
    </div>

    <!-- BODY -->
    <ul class="description">
      <li>{item1}</li>
      <li>{item2}</li>
      {item3 && <li>{item3}</li>}
      {item4 && <li>{item4}</li>}
      {item5 && <li>{item5}</li>}
    </ul>

    <!-- SKILLS (siempre abajo) -->
    {skills && (
      <div class="skills">
        <span class="skills-title">Tech Stack</span>
        <div class="skills-grid">
          {skills.map((skill) => (
            <div class="skill">
              <img src={skill.img} alt={skill.name} />
              <span>{skill.name}</span>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</li>
<style>
  .link-card {
  list-style: none;
  background: #1c1f26;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 2rem;
  transition: all 0.3s ease;
  display: flex;
  margin-bottom: 20px;
}

.link-card:hover {
  transform: translateY(-6px);
  border-color: rgba(255,255,255,0.25);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.card-content {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

.logos {
  display: flex;
  gap: 1rem;
}

.logos img {
  width: 60px;
  height: 60px;
  object-fit: contain;
}

.title {
  font-family: monospace;
  font-size: 1.5rem;
  font-weight: 700;
  text-transform: uppercase;
  color: white;
}

.date {
  font-family: monospace;
  font-size: 0.9rem;
  opacity: 0.7;
  margin-top: 0.25rem;
}

.description {
  font-family: monospace;
  font-size: 0.95rem;
  color: white;
  line-height: 1.6;
  padding-left: 1rem;
}

.skills {
  margin-top: auto; /* 🔥 Empuja skills hacia abajo */
  margin-top: 2rem;
}

.skills-title {
  font-family: monospace;
  font-weight: bold;
  font-size: 1rem;
  display: block;
  margin-bottom: 0.75rem;
}

.skills-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

.skill {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 0.75rem;
  gap: 0.4rem;
}

.skill img {
  width: 32px;
  height: 32px;
  object-fit: contain;
}

/* COMPACT MODE */
.compact {
  padding: 1.5rem;
}

.compact .logos img {
  width: 45px;
  height: 45px;
}

.compact .title {
  font-size: 1.1rem;
}

.compact .description {
  font-size: 0.85rem;
}
</style>