---
import "animate.css";

interface Props {
  img: string;
  color: string;
  name: string;
  level: "Baja" | "Media" | "Alta" | number;
}

const { img, color, name, level } = Astro.props;

function hexToRgb(color: string) {
  if (color.startsWith("#")) {
    const bigint = parseInt(color.slice(1), 16);
    const r = (bigint >> 16) & 255;
    const g = (bigint >> 8) & 255;
    const b = bigint & 255;
    return { r, g, b };
  }
  return { r: 255, g: 255, b: 255 };
}

function rgba(color: string, opacity: number) {
  const { r, g, b } = hexToRgb(color);
  return `rgba(${r}, ${g}, ${b}, ${opacity})`;
}

const levelValue =
  typeof level === "number"
    ? level
    : level === "Alta"
      ? 90
      : level === "Media"
        ? 60
        : 30;

const levelLabel =
  typeof level === "number"
    ? `${level}%`
    : level === "Alta"
      ? "Advanced"
      : level === "Media"
        ? "Intermediate"
        : "Basic";

const barColor     = rgba(color, 0.85);
const glowColor    = rgba(color, 0.4);
const bgColor      = rgba(color, 0.06);
const borderColor  = rgba(color, 0.2);
---

<li
  class="skill-item group w-full flex flex-col gap-3 py-3 px-1"
  style={`--bar-color: ${barColor}; --glow-color: ${glowColor}; --bg-color: ${bgColor}; --border-color: ${borderColor};`}
>
  <!-- Top row: icon + name + level badge -->
  <div class="flex items-center justify-between gap-3">

    <div class="flex items-center gap-3">
      <!-- Icon wrapper -->
      <div class="icon-wrap shrink-0 w-9 h-9 flex items-center justify-center rounded-md
        border border-white/5 bg-white/[0.03]
        transition-all duration-300
        group-hover:border-[var(--border-color)] group-hover:bg-[var(--bg-color)]"
      >
        <img src={img} alt={name} class="w-5 h-5 object-contain transition-transform duration-300 group-hover:scale-110" />
      </div>

      <!-- Name -->
      <span class="font-mono text-sm text-white/70 group-hover:text-white transition-colors duration-300">
        {name}
      </span>
    </div>

    <!-- Level badge -->
    <span class="level-badge font-mono text-[10px] tracking-widest uppercase px-2 py-0.5
      border rounded-sm text-white/40
      border-white/5 bg-white/[0.02]
      group-hover:text-white/70
      transition-colors duration-300"
      style="group-hover:border-color: var(--border-color);"
    >
      {levelLabel}
    </span>
  </div>

  <!-- Progress bar -->
  <div class="bar-track w-full h-[3px] bg-white/[0.05] rounded-full overflow-visible relative">

    <!-- Fill -->
    <div
      class="bar-fill h-full rounded-full relative"
      style={`width: ${levelValue}%; background: var(--bar-color);`}
    >
      <!-- Glow tail -->
      <span
        class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 rounded-full -translate-x-1/2
          opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        style={`background: var(--bar-color); box-shadow: 0 0 8px 3px var(--glow-color);`}
      ></span>
    </div>

    <!-- Tick marks -->
    {[25, 50, 75].map((tick) => (
      <span
        class="absolute top-1/2 -translate-y-1/2 w-px h-2 bg-white/10 rounded-full"
        style={`left: ${tick}%;`}
      ></span>
    ))}
  </div>
</li>

<style>
  .skill-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    transition: background 0.3s ease;
    border-radius: 4px;
  }

  .skill-item:last-child {
    border-bottom: none;
  }

  .skill-item:hover {
    background: rgba(255, 255, 255, 0.015);
  }

  /* Bar fill entrance animation */
  .bar-fill {
    animation: barGrow 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.2s;
    transform-origin: left;
  }

  @keyframes barGrow {
    from { width: 0% !important; opacity: 0.4; }
    to   { opacity: 1; }
  }
</style>