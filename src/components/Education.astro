---
import '../css/education.css';

interface Skill {
  name: string;
  img: string;
}

interface Certificate {
  img?: string;
  link?: string;
  label?: string;
  labelKey?: string;  // ← i18n key for the button label
  title?: string;
  titleKey?: string;  // ← i18n key for the certificate title
}

interface Props {
  // Institution
  institutionLogo: string;
  institutionLogo2?: string;
  institution: string;

  // Degree / course
  degree: string;
  degreeKey?: string; // ← i18n key for degree title
  type?: "degree" | "course" | "bootcamp" | "certification";

  // Dates
  startDate: string;
  endDate?: string;

  // Content
  description?: string;
  descriptionKey?: string;    // ← i18n key for description
  achievements?: string[];
  achievementKeys?: string[]; // ← i18n keys for each achievement item

  // Skills
  skills?: Skill[];

  // Certificates
  certificates?: Certificate[];

  compact?: boolean;
}

const {
  institutionLogo,
  institutionLogo2,
  institution,
  degree,
  degreeKey,
  type = "degree",
  startDate,
  endDate,
  description,
  descriptionKey,
  achievements,
  achievementKeys,
  skills,
  certificates,
  compact = false,
} = Astro.props;

const certList: Certificate[] = Array.isArray(certificates) ? certificates : [];

const slug = degree.toLowerCase().replace(/\s+/g, "_").replace(/[^a-z0-9_]/g, "");

const typeLabel: Record<string, string> = {
  degree:        "degree",
  course:        "course",
  bootcamp:      "bootcamp",
  certification: "cert",
};

// endDate label — "Present" will be swapped by i18n if data-i18n="edu.present"
const showPresent = !endDate;
const dateRange = `${startDate} → `;
---

<li
  data-aos="fade-up"
  data-aos-duration="2000"
  class="edu-card group relative overflow-hidden
    w-[95vw] sm:w-[85vw] md:w-[70vw] lg:w-[62vw] xl:w-[56vw]
    mb-5 flex flex-col"
>
  <!-- Corner accents -->
  <span class="corner corner-tl"></span>
  <span class="corner corner-tr"></span>
  <span class="corner corner-bl"></span>
  <span class="corner corner-br"></span>

  <!-- ── Top bar ── -->
  <div class="topbar flex items-center gap-2 px-4 py-2.5 border-b border-white/10 shrink-0">
    <span class="dot dot-red"></span>
    <span class="dot dot-yellow"></span>
    <span class="dot dot-green"></span>
    <span class="font-mono text-[10px] text-white/25 ml-2 tracking-widest truncate">
      {slug}.edu
    </span>
    <div class="ml-auto flex items-center gap-3 shrink-0">
      <span class="type-badge font-mono text-[10px] uppercase tracking-widest
        px-2 py-0.5 rounded-sm border border-[#4ade80]/20 bg-[#4ade80]/[0.05]
        text-[#4ade80]/60">
        {typeLabel[type]}
      </span>
      <span class="font-mono text-[10px] text-white/25 tracking-widest hidden sm:block">
        {dateRange}{showPresent
          ? <span data-i18n="edu.present">Present</span>
          : endDate
        }
      </span>
    </div>
  </div>

  <!-- ── Main content ── -->
  <div class="p-5 sm:p-7 flex flex-col gap-5">

    <!-- Header: logos + institution + degree -->
    <div class="flex flex-col sm:flex-row sm:items-start gap-4">
      <!-- Logos -->
      <div class="flex items-center gap-3 shrink-0">
        <div class="logo-wrap">
          <img src={institutionLogo} alt={institution}
            class="w-14 h-14 sm:w-16 sm:h-16 object-contain" />
        </div>
        {institutionLogo2 && !compact && (
          <div class="logo-wrap hidden sm:flex">
            <img src={institutionLogo2} alt={institution}
              class="w-14 h-14 sm:w-16 sm:h-16 object-contain" />
          </div>
        )}
      </div>

      <!-- Titles -->
      <div class="flex flex-col gap-1 min-w-0">
        <span class="font-mono text-xs text-[#4ade80]/60 tracking-widest uppercase flex items-center gap-1.5">
          <span class="text-[#4ade80]">▶</span> {institution}
        </span>
        <h2 class={`font-mono font-bold text-white uppercase tracking-tight leading-tight
          ${compact ? "text-base" : "text-lg sm:text-xl md:text-2xl"}`} data-i18n={degreeKey}>
          {degree}
        </h2>
        <!-- Date mobile -->
        <span class="font-mono text-xs text-white/30 sm:hidden mt-0.5">
          {dateRange}{showPresent
            ? <span data-i18n="edu.present">Present</span>
            : endDate
          }
        </span>
        <div class="h-px w-10 bg-gradient-to-r from-[#4ade80] to-transparent mt-1"></div>
      </div>
    </div>

    <!-- Description -->
    {description && (
      <div>
        <span
          class="font-mono text-[10px] text-white/20 tracking-[0.2em] uppercase"
          data-i18n="edu.comment_about"
        >// about</span>
        <p
          class="font-mono text-sm text-white/55 leading-relaxed mt-1.5"
          data-i18n={descriptionKey}
        >
          {description}
        </p>
      </div>
    )}

    <!-- Achievements -->
    {achievements && achievements.length > 0 && (
      <div>
        <span
          class="font-mono text-[10px] text-white/20 tracking-[0.2em] uppercase"
          data-i18n="edu.comment_achievements"
        >// achievements</span>
        <ul class="flex flex-col gap-2 mt-2">
          {achievements.map((item, i) => (
            <li class="ach-item flex gap-3 items-start font-mono text-sm text-white/55 leading-relaxed">
              <span class="ach-num shrink-0 text-[#4ade80]/35 text-xs pt-0.5 w-5 text-right select-none">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="text-white/20 shrink-0">→</span>
              <!-- data-i18n swaps only this span's text -->
              <span data-i18n={achievementKeys?.[i]}>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Skills -->
    {skills && skills.length > 0 && (
      <div class="border-t border-white/5 pt-4">
        <span
          class="font-mono text-[10px] text-white/20 tracking-[0.2em] uppercase"
          data-i18n="edu.comment_skills"
        >// skills_learned</span>
        <div class="flex flex-wrap gap-3 mt-3">
          {skills.map((skill) => (
            <div class="skill-chip group/chip flex flex-col items-center gap-1.5 px-3 py-2 cursor-default">
              <img src={skill.img} alt={skill.name}
                class={`object-contain transition-transform duration-300 group-hover/chip:scale-110
                  ${compact ? "w-7 h-7" : "w-8 h-8 sm:w-9 sm:h-9"}`} />
              <span class="font-mono text-[10px] sm:text-xs text-white/40
                group-hover/chip:text-[#4ade80] transition-colors duration-300">
                {skill.name}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Certificates -->
    {certList.length > 0 && (
      <div class="border-t border-white/5 pt-4">
        <span
          class="font-mono text-[10px] text-white/20 tracking-[0.2em] uppercase"
          data-i18n={certList.length > 1 ? "edu.comment_certs" : "edu.comment_cert"}
        >
          {certList.length > 1 ? "// certificates" : "// certificate"}
        </span>

        <div class={`grid gap-3 mt-3 ${certList.length > 1 ? "grid-cols-1 sm:grid-cols-2" : "grid-cols-1"}`}>
          {certList.map((cert, ci) => {
            const certId = `cert-lb-${slug}-${ci}`;
            return (
              <div class="cert-item flex flex-col gap-2 p-3 rounded-md border border-white/5 bg-white/[0.015]
                hover:border-[#4ade80]/15 hover:bg-[#4ade80]/[0.02] transition-all duration-300">

                {cert.title && (
                  <span class="font-mono text-[10px] text-white/30 tracking-widest uppercase truncate" data-i18n={cert.titleKey}>
                    {cert.title}
                  </span>
                )}

                {cert.img && (
                  <div
                    class="cert-thumb group/thumb relative overflow-hidden rounded-md cursor-zoom-in
                      w-full h-24 border border-white/8 bg-[#070b10]"
                    data-cert-lb={certId}
                  >
                    <img
                      src={cert.img}
                      alt={cert.title ?? "Certificate"}
                      class="w-full h-full object-contain p-2
                        transition-transform duration-500 group-hover/thumb:scale-105"
                    />
                    <div class="absolute inset-0 bg-[#0d1117]/50 opacity-0
                      group-hover/thumb:opacity-100 transition-opacity duration-300
                      flex items-center justify-center">
                      <span class="font-mono text-[10px] text-white/70 tracking-widest uppercase flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
                        </svg>
                        zoom
                      </span>
                    </div>
                    <div class="cert-scan absolute inset-x-0 h-px bg-[#4ade80]/30 pointer-events-none"></div>
                  </div>
                )}

                <div class="flex gap-2">
                  {cert.img && (
                    <button
                      class="cert-action-btn cert-action-btn--view group/cb relative overflow-hidden
                        flex items-center gap-1.5 font-mono text-[10px] tracking-widest uppercase
                        px-3 py-2 rounded-md flex-1 justify-center"
                      data-cert-lb={certId}
                    >
                      <span class="cbg"></span>
                      <span class="cborder"></span>
                      <span class="relative z-10 flex items-center gap-1.5
                        text-white/45 group-hover/cb:text-white transition-colors duration-300">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round"
                            d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <!-- data-i18n="edu.btn_view" for static label -->
                        <span data-i18n="edu.btn_view">View</span>
                      </span>
                    </button>
                  )}
                  {cert.link && (
                    <a
                      href={cert.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="cert-action-btn cert-action-btn--link group/cb relative overflow-hidden
                        flex items-center gap-1.5 font-mono text-[10px] tracking-widest uppercase
                        px-3 py-2 rounded-md flex-1 justify-center"
                    >
                      <span class="cbg cbg--green"></span>
                      <span class="cborder cborder--green"></span>
                      <span class="relative z-10 flex items-center gap-1.5
                        text-[#4ade80]/55 group-hover/cb:text-[#4ade80] transition-colors duration-300">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round"
                            d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                        </svg>
                        <!-- cert.labelKey for entry-specific label, fallback to edu.btn_view -->
                        <span data-i18n={cert.labelKey ?? "edu.btn_view"}>
                          {cert.label ?? "View Certificate"}
                        </span>
                      </span>
                    </a>
                  )}
                </div>
              </div>
            )
          })}
        </div>
      </div>
    )}
  </div>

  <!-- Bottom glow line -->
  <div class="glow-line absolute bottom-0 left-[10%] right-[10%] h-px
    bg-gradient-to-r from-transparent via-[#4ade80]/40 to-transparent
    opacity-0 group-hover:opacity-100 transition-opacity duration-300">
  </div>
</li>

<!-- Lightboxes -->
{certList.map((cert, ci) => cert.img && (
  <div id={`cert-lb-${slug}-${ci}`}
    class="cert-lightbox fixed inset-0 hidden items-center justify-center z-[100] p-4">
    <div class="lb-bg absolute inset-0 bg-black/88 backdrop-blur-sm"></div>

    <div class="lb-box relative z-10 bg-[#0d1117] border border-white/10 rounded-lg
      overflow-hidden max-w-3xl w-full shadow-[0_0_60px_rgba(0,0,0,0.9)]">

      <!-- Top bar -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-white/10 bg-white/[0.02]">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="font-mono text-[10px] text-white/25 ml-2 tracking-widest truncate" data-i18n={cert.titleKey}>
          {cert.title ?? `${slug}_${ci + 1}`}.cert
        </span>
        {certList.length > 1 && (
          <span class="font-mono text-[10px] text-white/20 ml-2 tracking-widest">
            {ci + 1}/{certList.length}
          </span>
        )}
        <button class="lb-close ml-auto font-mono text-white/40 hover:text-white
          text-lg leading-none w-7 h-7 flex items-center justify-center
          rounded-sm hover:bg-white/[0.07] transition-all duration-200">
          ✕
        </button>
      </div>

      <!-- Image -->
      <div class="p-4 bg-[#070b10]">
        <img
          class="lb-img w-full max-h-[72vh] object-contain rounded-sm"
          src={cert.img} alt={cert.title ?? "Certificate"}
        />
      </div>

      <!-- Footer -->
      {cert.link && (
        <div class="px-4 py-3 border-t border-white/10 flex items-center justify-between">
          <span class="font-mono text-[10px] text-white/20 tracking-widest truncate" data-i18n={cert.titleKey}>
            {cert.title ?? degree}
          </span>
          <a href={cert.link} target="_blank" rel="noopener noreferrer"
            class="font-mono text-[10px] text-[#4ade80]/50 hover:text-[#4ade80]
              tracking-widest uppercase flex items-center gap-1.5 transition-colors duration-200 shrink-0 ml-4">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
            <span data-i18n="edu.btn_open_external">Open external</span>
          </a>
        </div>
      )}
    </div>
  </div>
))}

<script is:inline define:vars={{ slug, certCount: certList.length }}>
  (function () {
    function openLb(id) {
      var lb = document.getElementById(id);
      if (!lb) return;
      lb.classList.remove("hidden");
      lb.classList.add("flex");
      requestAnimationFrame(function () { lb.classList.add("lb-open"); });
      document.body.style.overflow = "hidden";
    }

    function closeLb(lb) {
      if (!lb) return;
      lb.classList.remove("lb-open");
      setTimeout(function () {
        lb.classList.add("hidden");
        lb.classList.remove("flex");
        document.body.style.overflow = "auto";
      }, 220);
    }

    for (var ci = 0; ci < certCount; ci++) {
      var lbId = "cert-lb-" + slug + "-" + ci;
      var lb   = document.getElementById(lbId);
      if (!lb) continue;

      document.querySelectorAll("[data-cert-lb='" + lbId + "']").forEach(function (el) {
        el.addEventListener("click", (function (id) {
          return function () { openLb(id); };
        })(lbId));
      });

      var closeBtn = lb.querySelector(".lb-close");
      var lbBg     = lb.querySelector(".lb-bg");
      if (closeBtn) closeBtn.addEventListener("click", (function (l) { return function () { closeLb(l); }; })(lb));
      if (lbBg)     lbBg.addEventListener("click",     (function (l) { return function () { closeLb(l); }; })(lb));
    }

    document.addEventListener("keydown", function (e) {
      if (e.key !== "Escape") return;
      document.querySelectorAll(".cert-lightbox.lb-open").forEach(function (lb) { closeLb(lb); });
    });
  })();
</script>
