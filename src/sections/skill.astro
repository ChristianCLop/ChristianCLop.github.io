---
<section id="skills" class="overflow-hidden relative py-24 sm:py-32">

  <!-- Grid background -->
  <div class="section-grid" aria-hidden="true"></div>

  <div class="flex flex-col items-center px-4 sm:px-8">

    <!-- ── Header ── -->
    <header
      class="w-full flex flex-col items-center mb-14 sm:mb-20"
      data-aos="fade-down"
      data-aos-duration="1200"
    >
      <span class="font-mono text-[11px] sm:text-xs text-[#4ade80]/50 tracking-[0.25em] uppercase mb-4">
        ~/portfolio/stack
      </span>

      <div class="title-wrap relative">
        <h1 class="font-mono font-black uppercase tracking-tight leading-none
          text-5xl sm:text-6xl md:text-7xl lg:text-8xl
          text-transparent select-none">
          My Stack
        </h1>
        <div class="h-[3px] mt-3 bg-gradient-to-r from-transparent via-[#4ade80] to-transparent rounded-full opacity-60"></div>
      </div>

      <p class="font-mono text-xs sm:text-sm text-white/25 mt-4 tracking-widest">
        <span class="text-[#4ade80]/50">▶</span> {skillCategories.length} categories loaded
      </p>
    </header>

    <!-- ── Categories grid ── -->
    <div
      class="w-full max-w-6xl"
      data-aos="fade-up"
      data-aos-duration="1600"
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {skillCategories.slice(0, 6).map((category, i) => (
          <div
            class="category-card group flex flex-col"
            data-aos="fade-up"
            data-aos-duration="1400"
            data-aos-delay={i * 80}
          >
            <!-- Card top bar -->
            <div class="card-topbar flex items-center gap-2 px-4 py-2.5 border-b border-white/10">
              <span class="font-mono text-[10px] text-[#4ade80]/50 tracking-widest">▸</span>
              <span class="font-mono text-xs text-white/40 tracking-widest uppercase truncate">
                {category.title}
              </span>
              <span class="ml-auto font-mono text-[10px] text-white/20">
                {category.items.length}
              </span>
            </div>

            <!-- Skills list -->
            <div class="card-body flex-1 p-4 sm:p-5">
              <ul class="flex flex-col">
                {category.items.map((skill) => (
                  <Skills {...skill} />
                ))}
              </ul>
            </div>

            <!-- Bottom accent line -->
            <div class="card-glow-line"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Show All button ── -->
    {skillCategories.length > 6 && (
      <div data-aos="zoom-out-up" data-aos-duration="2000" class="mt-12">
        <button
          id="showAllSkillsBtn"
          class="show-all-btn group relative font-mono text-sm uppercase tracking-widest px-8 py-3 overflow-hidden"
        >
          <span class="btn-bg"></span>
          <span class="btn-border"></span>
          <span class="relative z-10 flex items-center gap-2 text-white/70 group-hover:text-white transition-colors duration-300">
            <span class="text-[#4ade80] group-hover:animate-spin" style="display:inline-block">◈</span>
            Show All
            <span class="text-white/30 group-hover:text-[#4ade80] transition-colors duration-300 font-normal">
              ({skillCategories.length})
            </span>
          </span>
        </button>
      </div>
    )}
  </div>
</section>

<!-- ── Modal ── -->
<div
  id="skillsModal"
  class="modal-backdrop fixed inset-0 hidden justify-center items-center z-50 p-4 sm:p-6"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>

  <!-- Modal box -->
  <div class="modal-box relative bg-[#0d1117] border border-white/10 rounded-lg
    w-full max-w-6xl max-h-[92vh] overflow-hidden flex flex-col
    shadow-[0_0_60px_rgba(0,0,0,0.8)]"
  >
    <!-- Top bar -->
    <div class="modal-topbar flex items-center gap-2 px-5 py-3 border-b border-white/10 shrink-0">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
      <span class="font-mono text-xs text-white/30 ml-3 tracking-widest">all_stack.json</span>
      <button
        id="closeSkillsModal"
        class="close-btn ml-auto font-mono text-white/40 hover:text-white text-lg leading-none transition-colors duration-200"
        aria-label="Close modal"
      >✕</button>
    </div>

    <!-- Scroll area -->
    <div class="overflow-y-auto flex-1 p-4 sm:p-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {skillCategories.map((category, i) => (
          <div class="category-card group flex flex-col">
            <div class="card-topbar flex items-center gap-2 px-4 py-2.5 border-b border-white/10">
              <span class="font-mono text-[10px] text-[#4ade80]/50 tracking-widest">▸</span>
              <span class="font-mono text-xs text-white/40 tracking-widest uppercase truncate">
                {category.title}
              </span>
              <span class="ml-auto font-mono text-[10px] text-white/20">
                {category.items.length}
              </span>
            </div>
            <div class="card-body flex-1 p-4 sm:p-5">
              <ul class="flex flex-col">
                {category.items.map((skill) => (
                  <Skills {...skill} />
                ))}
              </ul>
            </div>
            <div class="card-glow-line"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom glow -->
    <div class="h-px bg-gradient-to-r from-transparent via-[#4ade80]/30 to-transparent shrink-0"></div>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const modal    = document.getElementById("skillsModal");
    const showBtn  = document.getElementById("showAllSkillsBtn");
    const closeBtn = document.getElementById("closeSkillsModal");
    const backdrop = modal?.querySelector(".absolute.inset-0");

    function openModal() {
      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => modal?.classList.add("modal-open"));
    }

    function closeModal() {
      modal?.classList.remove("modal-open");
      setTimeout(() => {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
        document.body.style.overflow = "auto";
      }, 250);
    }

    showBtn?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  });
</script>