---

<section id="skills" class="overflow-hidden">
  <div class="mt-28">
    <div class="flex flex-col px-10 py-10 bg-[#141419] relative z-10">
      <header>
        <h1
          class="mb-14 text-center text-4xl font-black text-transparent font-mono stroke-1 uppercase max-md:whitespace-nowrap"
        >
          My Stack
        </h1>
      </header>
      <div class="grid grid-cols-3 gap-x-16 gap-y-16">
        {
          skillCategories.slice(0, 6).map((category) => (
            <div class="border rounded-lg p-4">
              <h1>{category.title}</h1>
              {category.items.map((skill) => (
                <Skills {...skill} />
              ))}
            </div>
          ))
        }
      </div>
      {
        skillCategories.length > 6 && (
          <div class="mt-12 text-center">
            <button
              id="showAllSkillsBtn"
              class="px-6 py-3 border border-white font-mono uppercase rounded-xl"
            >
              Show All
            </button>
          </div>
        )
      }
      <div
        id="skillsModal"
        class="fixed inset-0 hidden justify-center items-center z-50"
      >
        <div
          class="bg-zinc-900 p-10 max-w-6xl w-full max-h-[90vh] overflow-y-auto rounded-xl relative"
        >
          <button
            id="closeSkillsModal"
            class="absolute top-6 right-8 text-white text-2xl"
          >
            ✕
          </button>

          <div class="grid grid-cols-3 gap-16 mt-6">
            {
              skillCategories.map((category) => (
                <div class="border rounded-lg p-4">
                  <h1>{category.title}</h1>
                  {category.items.map((skill) => (
                    <Skills {...skill} />
                  ))}
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("skillsModal");
    const showBtn = document.getElementById("showAllSkillsBtn");
    const closeBtn = document.getElementById("closeSkillsModal");

    showBtn?.addEventListener("click", () => {
      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
      document.body.style.overflow = "hidden";
    });

    closeBtn?.addEventListener("click", () => {
      modal?.classList.add("hidden");
      modal?.classList.remove("flex");
      document.body.style.overflow = "auto";
    });

    window.addEventListener("click", (e) => {
      if (e.target === modal) {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
        document.body.style.overflow = "auto";
      }
    });
  });
</script>