<style>
  /* ── Grid bg ── */
  .section-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(74, 222, 128, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(74, 222, 128, 0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    mask-image: radial-gradient(ellipse 100% 100% at 30% 50%, black 20%, transparent 80%);
  }

  /* ── Center radial glow ── */
  .center-glow {
    position: absolute;
    top: 50%;
    left: 20%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(74, 222, 128, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Name gradient ── */
  .name {
    background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.2) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.1);
    transition: -webkit-text-stroke 0.3s ease;
  }
  .name-wrap:hover .name {
    -webkit-text-stroke: 1.5px rgba(74,222,128,0.2);
  }

  /* ── Cursor blink ── */
  .cursor-blink {
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── Wave emoji ── */
  .wave {
    animation: wave 2.5s ease-in-out infinite;
    transform-origin: 70% 70%;
  }
  @keyframes wave {
    0%,100% { transform: rotate(0deg); }
    15%     { transform: rotate(14deg); }
    30%     { transform: rotate(-8deg); }
    45%     { transform: rotate(14deg); }
    60%     { transform: rotate(-4deg); }
    75%     { transform: rotate(10deg); }
  }

  /* ── Social cards ── */
  .social-card {
    background: #0d1117;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.3s ease;
  }
  .social-card:hover { transform: translateY(-2px); }

  .social-card-bg {
    position: absolute; inset: 0;
    background: rgba(255,255,255,0.02);
    border-radius: inherit;
    transition: background 0.3s ease;
  }
  .social-card:hover .social-card-bg { background: rgba(74,222,128,0.04); }
  .social-card--github:hover .social-card-bg { background: rgba(255,255,255,0.04); }

  .social-card-border {
    position: absolute; inset: 0;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: inherit;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .social-card:hover .social-card-border {
    border-color: rgba(74,222,128,0.3);
    box-shadow: 0 0 20px rgba(74,222,128,0.08), 0 4px 16px rgba(0,0,0,0.4);
  }
  .social-card--github:hover .social-card-border {
    border-color: rgba(255,255,255,0.18);
    box-shadow: 0 0 20px rgba(255,255,255,0.04), 0 4px 16px rgba(0,0,0,0.4);
  }

  .social-card-shine {
    position: absolute; inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.04) 50%, transparent 60%);
    background-size: 200% 200%;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .social-card:hover .social-card-shine {
    opacity: 1;
    animation: cardShine 1.2s ease forwards;
  }
  @keyframes cardShine {
    from { background-position: 200% 0; }
    to   { background-position: -200% 0; }
  }

  /* ── Scroll indicator ── */
  .scroll-indicator {
    width: 1px;
    height: 20px;
    background: linear-gradient(to bottom, transparent, rgba(74,222,128,0.5), transparent);
    animation: scrollPulse 1.8s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50%       { opacity: 1;   transform: scaleY(1.1); }
  }
</style>