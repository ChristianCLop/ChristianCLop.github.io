---
import "../css/home.css";
---

<section id="home" class="overflow-hidden relative min-h-screen flex items-center justify-center">

  <!-- Grid background -->
  <div class="section-grid" aria-hidden="true"></div>

  <!-- Radial glow center -->
  <div class="center-glow" aria-hidden="true"></div>

  <div class="relative z-10 w-full max-w-4xl px-6 sm:px-10 flex flex-col items-start">

    <!-- ── Terminal prompt line ── -->
    <div
      class="flex items-center gap-2 mb-6"
      data-aos="fade-down"
      data-aos-duration="1000"
    >
      <span class="font-mono text-[#4ade80]/60 text-sm tracking-widest">~/portfolio</span>
      <span class="font-mono text-white/20 text-sm">$</span>
      <span class="font-mono text-white/40 text-sm typing-cmd">whoami</span>
      <span class="cursor-blink font-mono text-[#4ade80] text-sm">▌</span>
    </div>

    <!-- ── Greeting ── -->
    <div
      data-aos="fade-right"
      data-aos-duration="1000"
      data-aos-delay="200"
      class="flex items-center gap-3 mb-3"
    >
      <span class="font-mono text-[10px] text-white/20 tracking-[0.2em] uppercase">// greeting</span>
      <div class="h-px w-8 bg-white/10"></div>
    </div>

    <p
      data-aos="fade-right"
      data-aos-duration="1000"
      data-aos-delay="300"
      class="font-mono text-xl sm:text-2xl text-white/50 mb-2"
    >
      Hi there <span class="wave inline-block">👋</span>, I'm
    </p>

    <!-- ── Name ── -->
    <div
      data-aos="fade-up"
      data-aos-duration="1200"
      data-aos-delay="400"
      class="name-wrap relative mb-2"
    >
      <h1 class="name font-mono font-black uppercase tracking-tight leading-none
        text-6xl sm:text-7xl md:text-8xl lg:text-9xl
        text-transparent select-none">
        Christian
      </h1>
      <h1 class="name font-mono font-black uppercase tracking-tight leading-none
        text-6xl sm:text-7xl md:text-8xl lg:text-9xl
        text-transparent select-none">
        Chico
      </h1>
    </div>

    <!-- ── Role tag ── -->
    <div
      data-aos="fade-up"
      data-aos-duration="1000"
      data-aos-delay="600"
      class="flex items-center gap-3 mt-4 mb-8"
    >
      <span class="role-badge flex items-center gap-2 font-mono text-xs sm:text-sm
        tracking-widest uppercase px-3 py-1.5
        border border-[#4ade80]/25 bg-[#4ade80]/5 rounded-sm text-[#4ade80]/80">
        <span class="w-1.5 h-1.5 rounded-full bg-[#4ade80] animate-pulse"></span>
        Full-Stack Developer
      </span>
      <span class="hidden sm:block h-px flex-1 max-w-[80px] bg-gradient-to-r from-[#4ade80]/20 to-transparent"></span>
    </div>

    <!-- ── Underline accent ── -->
    <div
      data-aos="fade-right"
      data-aos-duration="800"
      data-aos-delay="700"
      class="h-[2px] w-24 sm:w-32 bg-gradient-to-r from-[#4ade80] to-transparent rounded-full mb-10 opacity-60"
    ></div>

    <!-- ── Social links ── -->
    <div
      class="flex flex-col gap-4 w-full sm:w-auto"
      data-aos="fade-up"
      data-aos-duration="1000"
    >
      <!-- Label -->
      <span class="font-mono text-[10px] text-white/20 tracking-[0.2em] uppercase">
        // connect
      </span>

      <div class="flex flex-col sm:flex-row gap-3">

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/christianchicolópez"
          target="_blank"
          rel="noopener noreferrer"
          class="social-card group relative overflow-hidden flex items-center gap-4
            px-5 py-4 rounded-md
            w-full sm:w-56"
          aria-label="LinkedIn"
        >
          <!-- Bg layers -->
          <span class="social-card-bg"></span>
          <span class="social-card-border"></span>
          <span class="social-card-shine"></span>

          <!-- Icon -->
          <span class="social-icon-wrap relative z-10 flex items-center justify-center
            w-10 h-10 rounded-md shrink-0
            border border-white/8 bg-white/[0.03]
            group-hover:border-[#0077b5]/40 group-hover:bg-[#0077b5]/10
            transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" height="18" width="18">
              <path stroke="currentColor" stroke-linejoin="round" d="M1.5 3.5a2 2 0 1 0 4 0 2 2 0 1 0 -4 0" stroke-width="1.5"/>
              <path stroke="currentColor" stroke-linejoin="round" d="M1.5 22.5v-14h4v14h-4Z" clip-rule="evenodd" stroke-width="1.5"/>
              <path stroke="currentColor" stroke-linejoin="round" d="M8 8.5v14h4v-6.908c0 -1.092 1 -3.092 3.895 -3.092 1.643 0 2.605 0.845 2.605 2.5v7.5h4V15c0 -1.309 -0.312 -2.937 -1.394 -4.277 -1.144 -1.417 -2.913 -2.223 -5.21 -2.223 -1.513 0 -2.835 0.615 -3.896 1.366V8.5H8Z" clip-rule="evenodd" stroke-width="1.5"/>
            </svg>
          </span>

          <!-- Text -->
          <span class="relative z-10 flex flex-col">
            <span class="font-mono text-sm font-semibold text-white/80 group-hover:text-white transition-colors duration-300">
              LinkedIn
            </span>
            <span class="font-mono text-[10px] text-white/25 group-hover:text-[#0077b5]/70 transition-colors duration-300 tracking-wide">
              /in/christianchico
            </span>
          </span>

          <!-- Arrow -->
          <span class="relative z-10 ml-auto font-mono text-white/15 group-hover:text-white/50
            group-hover:translate-x-0.5 transition-all duration-300 text-sm">
            →
          </span>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/ChristianCLop"
          target="_blank"
          rel="noopener noreferrer"
          class="social-card social-card--github group relative overflow-hidden flex items-center gap-4
            px-5 py-4 rounded-md
            w-full sm:w-56"
          aria-label="GitHub"
        >
          <span class="social-card-bg"></span>
          <span class="social-card-border"></span>
          <span class="social-card-shine"></span>

          <!-- Icon -->
          <span class="social-icon-wrap relative z-10 flex items-center justify-center
            w-10 h-10 rounded-md shrink-0
            border border-white/8 bg-white/[0.03]
            group-hover:border-white/20 group-hover:bg-white/[0.07]
            transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" height="18" width="18">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M11.996 1.771a10.486 10.486 0 0 0 -3.314 20.438c0.523 0.092 0.69 -0.216 0.69 -0.493 0 -0.25 0.005 -0.945 0 -1.824 -2.919 0.633 -3.522 -1.381 -3.522 -1.381a2.775 2.775 0 0 0 -1.163 -1.534c-0.952 -0.65 0.071 -0.638 0.071 -0.638a2.201 2.201 0 0 1 1.607 1.08 2.232 2.232 0 0 0 3.05 0.871c0.05 -0.53 0.285 -1.025 0.666 -1.397 -2.328 -0.266 -4.776 -1.165 -4.776 -5.184a4.055 4.055 0 0 1 1.08 -2.815 3.762 3.762 0 0 1 0.103 -2.774s0.882 -0.282 2.883 1.076a9.924 9.924 0 0 1 5.252 0c2.007 -1.357 2.881 -1.076 2.881 -1.076 0.387 0.878 0.424 1.87 0.104 2.774a4.05 4.05 0 0 1 1.079 2.816c0 4.03 -2.452 4.916 -4.789 5.174a2.487 2.487 0 0 1 0.718 1.933v2.904c0 0.28 0.17 0.59 0.702 0.488a10.487 10.487 0 0 0 -3.322 -20.438v0Z" stroke-width="1.5"/>
            </svg>
          </span>

          <!-- Text -->
          <span class="relative z-10 flex flex-col">
            <span class="font-mono text-sm font-semibold text-white/80 group-hover:text-white transition-colors duration-300">
              GitHub
            </span>
            <span class="font-mono text-[10px] text-white/25 group-hover:text-white/50 transition-colors duration-300 tracking-wide">
              /ChristianCLop
            </span>
          </span>

          <!-- Arrow -->
          <span class="relative z-10 ml-auto font-mono text-white/15 group-hover:text-white/50
            group-hover:translate-x-0.5 transition-all duration-300 text-sm">
            →
          </span>
        </a>
      </div>

      <!-- Scroll hint below -->
      <div class="hidden sm:flex items-center gap-2 mt-1 font-mono text-[10px] text-white/15 tracking-widest uppercase">
        <div class="scroll-indicator"></div>
        scroll down
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 inset-x-0 h-32
    bg-gradient-to-t from-[#0d1117] to-transparent pointer-events-none">
  </div>

</section>
