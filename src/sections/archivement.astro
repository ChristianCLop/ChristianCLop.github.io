---
import Archivements from "../components/Archivements.astro";

const archivements = [
  {
    img: "/img/archivements/Python Essentials 1.png",
    title: "Python Essentials",
    body: "Python Essentials 1",
    date: "February 19, 2026",
    link: "https://drive.google.com/file/d/1OpayUwHpEWC_LVi2mSlZT6wtxQy5DLjS/view?usp=sharing",
  },
  {
    img: "/img/archivements/cybersecurity.png",
    title: "Cybersecurity",
    body: "Introduction to Cybersecurity",
    date: "November 03, 2024",
    link: "https://drive.google.com/file/d/1_bmQsga2yVHQXWOIFWbqQ-P-Z26J-k_b/view?usp=drive_link",
  },
  {
    img: "/img/archivements/AI Fundamentals.png",
    title: "AI",
    body: "AI Fundamentals",
    date: "November 15, 2024",
    link: "https://drive.google.com/file/d/1wLG311guenZzt0kmB3-tAAOHtrXpDoOT/view?usp=drive_link",
  },
  {
    img: "/img/archivements/java.jpg",
    title: "JAVA Programming degree",
    body: "Java Basics",
    date: "March 30, 2024",
    link: "https://drive.google.com/file/d/1AJMvviNfzwzL0hZ7eOiSsyGKMjD--q_i/view?usp=drive_link",
  },
  {
    img: "/img/archivements/php.jpg",
    title: "PHP Programming degree",
    body: "PHP Basics",
    date: "April 13, 2024",
    link: "https://drive.google.com/file/d/1gSxeQOg0VHJW0eScWqIuftrP86sp96ac/view?usp=drive_link",
  },
  {
    img: "/img/archivements/CSEI 24 PAPER 9 Presentation.png",
    title:
      "Emerging Research Frontiers in Computer Science, Electronics and Industrial Engineering",
    body: "CSEI 24 PAPER 9",
    date: "October 25, 2024",
    link: "https://drive.google.com/file/d/1rRLd2yZk8c5z8TigoyYGJILH1tX2ucny/view?usp=drive_link",
  },
  {
    img: "/img/archivements/EthicalHacking.jpg",
    title: "Ethical Hacking | Red Team 2da edición",
    body: "Hacker Mentor",
    date: "October 10, 2022",
    link: "https://drive.google.com/file/d/1lUI-zu6I4ndb7P4Md3bqWhmolun4cFHi/view?usp=drive_link",
  },
];
---

<section id="achievements" class="overflow-hidden relative py-24 sm:py-32">

  <!-- Grid background -->
  <div class="section-grid" aria-hidden="true"></div>

  <div class="flex flex-col items-center px-4 sm:px-8">

    <!-- ── Header ── -->
    <header
      class="w-full flex flex-col items-center mb-14 sm:mb-20"
      data-aos="fade-down"
      data-aos-duration="1200"
    >
      <span class="font-mono text-[11px] sm:text-xs text-[#4ade80]/50 tracking-[0.25em] uppercase mb-4">
        ~/portfolio/achievements
      </span>

      <div class="title-wrap relative">
        <h1 class="font-mono font-black uppercase tracking-tight leading-none
          text-5xl sm:text-6xl md:text-7xl lg:text-8xl
          text-transparent select-none">
          Achievements
        </h1>
        <div class="h-[3px] mt-3 bg-gradient-to-r from-transparent via-[#4ade80] to-transparent rounded-full opacity-60"></div>
      </div>

      <p class="font-mono text-xs sm:text-sm text-white/25 mt-4 tracking-widest">
        <span class="text-[#4ade80]/50">▶</span> {archivements.length} certificates indexed
      </p>
    </header>

    <!-- ── Cards grid ── -->
    <div class="w-full max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6 justify-items-center">
        {archivements.slice(0, 6).map((item, i) => (
          <div
            data-aos="fade-up"
            data-aos-duration="1400"
            data-aos-delay={i * 80}
            class="w-full flex justify-center"
          >
            <Archivements {...item} />
          </div>
        ))}
      </div>
    </div>

    <!-- ── Show All button ── -->
    {archivements.length > 6 && (
      <div data-aos="zoom-out-up" data-aos-duration="2000" class="mt-12">
        <button
          id="showAllBtn"
          class="show-all-btn group relative font-mono text-sm uppercase tracking-widest px-8 py-3 overflow-hidden"
        >
          <span class="btn-bg"></span>
          <span class="btn-border"></span>
          <span class="relative z-10 flex items-center gap-2 text-white/70 group-hover:text-white transition-colors duration-300">
            <span class="text-[#4ade80] group-hover:animate-spin" style="display:inline-block">◈</span>
            Show All
            <span class="text-white/30 group-hover:text-[#4ade80] transition-colors duration-300 font-normal">
              ({archivements.length})
            </span>
          </span>
        </button>
      </div>
    )}

  </div>
</section>

<!-- ── Modal ── -->
<div
  id="modalArch"
  class="modal-backdrop fixed inset-0 hidden justify-center items-center z-50 p-4 sm:p-6"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>

  <!-- Modal box -->
  <div class="modal-box relative bg-[#0d1117] border border-white/10 rounded-lg
    w-full max-w-7xl max-h-[92vh] overflow-hidden flex flex-col
    shadow-[0_0_60px_rgba(0,0,0,0.8)]"
  >
    <!-- Top bar -->
    <div class="modal-topbar flex items-center gap-2 px-5 py-3 border-b border-white/10 shrink-0">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
      <span class="font-mono text-xs text-white/30 ml-3 tracking-widest">all_achievements.json</span>
      <span class="ml-auto font-mono text-[10px] text-[#4ade80]/40 tracking-widest hidden sm:block">
        {archivements.length} entries
      </span>
      <button
        id="closeModalArch"
        class="close-btn sm:ml-4 font-mono text-white/40 hover:text-white text-lg leading-none transition-colors duration-200"
        aria-label="Close modal"
      >✕</button>
    </div>

    <!-- Scroll area -->
    <div class="overflow-y-auto flex-1 p-4 sm:p-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-5 justify-items-center">
        {archivements.map((item) => (
          <div class="w-full flex justify-center">
            <Archivements {...item} compact={true} />
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom glow -->
    <div class="h-px bg-gradient-to-r from-transparent via-[#4ade80]/30 to-transparent shrink-0"></div>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const modal    = document.getElementById("modalArch");
    const showBtn  = document.getElementById("showAllBtn");
    const closeBtn = document.getElementById("closeModalArch");
    const backdrop = modal?.querySelector(".absolute.inset-0");

    function openModal() {
      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => modal?.classList.add("modal-open"));
    }

    function closeModal() {
      modal?.classList.remove("modal-open");
      setTimeout(() => {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
        document.body.style.overflow = "auto";
      }, 250);
    }

    showBtn?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  });
</script>

<style>
  /* ── Grid bg ── */
  .section-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(74, 222, 128, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(74, 222, 128, 0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 100%);
  }

  /* ── Title ── */
  .title-wrap h1 {
    background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.15) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.12);
  }

  /* ── Show All button ── */
  .show-all-btn {
    border-radius: 6px;
    cursor: pointer;
    background: transparent;
    border: none;
    outline: none;
  }
  .btn-bg {
    position: absolute; inset: 0;
    background: rgba(255,255,255,0.03);
    border-radius: 6px;
    transition: background 0.3s ease;
  }
  .show-all-btn:hover .btn-bg {
    background: rgba(74, 222, 128, 0.06);
  }
  .btn-border {
    position: absolute; inset: 0;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .show-all-btn:hover .btn-border {
    border-color: rgba(74, 222, 128, 0.35);
    box-shadow: 0 0 16px rgba(74, 222, 128, 0.08);
  }

  /* ── Modal backdrop ── */
  .modal-backdrop {
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .modal-backdrop.modal-open { opacity: 1; }

  /* ── Modal box slide-in ── */
  .modal-box {
    transform: translateY(16px) scale(0.98);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease;
  }
  .modal-open .modal-box {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* ── Modal scrollbar ── */
  .modal-box ::-webkit-scrollbar       { width: 4px; }
  .modal-box ::-webkit-scrollbar-track { background: transparent; }
  .modal-box ::-webkit-scrollbar-thumb {
    background: rgba(74, 222, 128, 0.2);
    border-radius: 2px;
  }
  .modal-box ::-webkit-scrollbar-thumb:hover {
    background: rgba(74, 222, 128, 0.4);
  }

  /* ── Terminal dots ── */
  .dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    display: inline-block;
    opacity: 0.65;
  }
  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }

  /* ── Close button ── */
  .close-btn {
    background: none; border: none; cursor: pointer;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 4px;
    transition: background 0.2s ease;
  }
  .close-btn:hover { background: rgba(255,255,255,0.07); }
</style>
